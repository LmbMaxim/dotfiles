
monitor=HDMI-A-1,1920x1080@100,auto, auto

exec_always {
    # gsettings set $gnome-schema gtk-theme Graphite-compact
    # gsettings set $gnome-schema icon-theme 'Your icon theme'
    # gsettings set $gnome-schema cursor-theme 'Your cursor Theme'
    # gsettings set $gnome-schema font-name 'Your font name'
}
exec-once = xdg-desktop-portal-gtk
exec-once = waybar -c ~/.config/waybar/hypr_config -s ~/.config/waybar/style.css
#exec-once = /usr/lib/polkit-kde-authentication-agent-1
exec-once = /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec-once = copyq
exec-once = swaync 
#exec-once = swaybg -i ~/Images/angryimg.png
#exec-once = sleep 10 && swww init
#exec-once = swww img ~/Shorts/animated_gradient_2.gif
exec-once = mpvpaper -o "no-audio --loop" '*' Images/wallpappers/animated_gradient.webm 
exec-once = /usr/bin/hyprland-per-window-layout
exec-once = foot -s
exec-once = pypr
exec-once = udiskie 
exec-once = corectrl


# Source a file (multi-file configs)
# source = ~/.config/hypr/myColors.conf

# Some default env vars.
env = XCURSOR_SIZE,15



# For all categories, see https://wiki.hyprland.org/Configuring/Variables/
input {
    repeat_delay = 300          
    repeat_rate = 50
    kb_layout = us, ru
    kb_variant = 
    kb_model = pc86
    kb_options = grp:win_space_toggle, ctrl:swapcaps, caps:swapctrl    kb_rules =
    
    # accel_profile = none
    follow_mouse = 1
    force_no_accel = 1

    sensitivity = -1  # -1.0 - 1.0, 0 means no modification.
}

general {
    # See https://wiki.hyprland.org/Configuring/Variables/ for more

    gaps_in = 2
    gaps_out = 2
    border_size = 1
    # col.active_border = rgba(33ccffee) rgba(00ff99ee) 45deg
    col.active_border = rgba(00000000)
    col.inactive_border = rgba(ffffffd9)

    layout = dwindle
}

decoration {
  blur {
    ignore_opacity = true
    enabled = false
    size = 1
    passes = 1

  } 
}
layerrule = blur, rofi

animations {
    enabled = yes

    # Some default animations, see https://wiki.hyprland.org/Configuring/Animations/ for more

    bezier = myBezier, 0.05, 0.9, 0.1, 1.05

    animation = windows, 1, 7, myBezier
    animation = windowsOut, 1, 7, default, popin 80%
    animation = border, 1, 10, default
    animation = borderangle, 1, 8, default
    animation = fade, 1, 7, default
    animation = workspaces, 1, 6, default
}

dwindle {
    # See https://wiki.hyprland.org/Configuring/Dwindle-Layout/ for more
    pseudotile = yes # master switch for pseudotiling. Enabling is bound to mainMod + P in the keybinds section below
    preserve_split = yes # you probably want this
    no_gaps_when_only = yes
}

master {
    # See https://wiki.hyprland.org/Configuring/Master-Layout/ for more
    new_is_master = true
}


# Example per-device config
# See https://wiki.hyprland.org/Configuring/Keywords/#executing for more
device:epic-mouse-v1 {
    sensitivity = -0.5
}


# Example windowrule v1
# windowrule = float, ^(kitty)$
# Example windowrule v2
# windowrulev2 = float,class:^(kitty)$,title:^(kitty)$
# See https://wiki.hyprland.org/Configuring/Window-Rules/ for more

# windowrule=noanim,^(REAPER)$

windowrulev2 = nofocus,class:REAPER,title:^$
windowrulev2 = stayfocused,title:(Metronome and pre-roll settings)


windowrulev2 = pseudo,class:^(org.wezfurlong.wezterm)$

layerrule = blur, rofi

# See https://wiki.hyprland.org/Configuring/Keywords/ for more
$mainMod = SUPER

# Pyprland plagins configuration

bind = ,Print, exec, grimblast save output

# Repeat this for each scratchpad you need

# Repeat this for each scratchpad you need
bind = $mainMod, M,exec,pypr toggle music
windowrule = float, ^(ymuse)$
windowrule = pin, ^(ymuse)$
# windowrule = noanim, ^(ymuse)$
windowrule = workspace special silent, ^(ymuse)$


# bind = $mainMod, Z,exec,pypr toggle metronome
# windowrule = float, ^(gmetronome)$
# windowrule = workspace special silent, ^(gmetronome)$

# bind = $mainMod, X,exec,pypr toggle patchage
# windowrule = float, ^(Patchage)$
# windowrule = workspace special silent, ^(Patchage)$

# windowrule = float, ^(de.haeckerfelix.Fragments)$
# windowrule = workspace special silent, ^(de.haeckerfelix.Fragments)$




# Example binds, see https://wiki.hyprland.org/Configuring/Binds/ for more
bind = $mainMod SHIFT, Return, exec, footclient
bind = $mainMod, Return, exec, rofi -show drun -terminal foot
bind = $mainMod, `, exec, rofi -show window
bind = $mainMod, Q, killactive, 


bind = $mainMod, E, exec, nemo
bind = $mainMod, F, togglefloating, 
bind = $mainMod, mouse:274, togglefloating, 
bind = $mainMod SHIFT, F, fullscreen, 
# bind = $mainMod, , pseudo, # dwindle
# bind = $mainMod, J, togglesplit, # dwindle

# Move focus with mainMod + arrow keys
bind = $mainMod, l, movefocus, l
bind = $mainMod, h, movefocus, r
bind = $mainMod, j, cyclenext,
bind = $mainMod, k, cyclenext, prev
# bind = $mainMod, up, movefocus, u
# bind = $mainMod, down, movefocus, d
#
bind = SUPER, C, movetoworkspace, special
bind = SUPER, V, togglespecialworkspace,

bind=SUPER,Tab,workspace,e+1
bind=SUPER,mouse_up,workspace,e+1
bind=SUPER,mouse_down,workspace,e-1

# Switch workspaces with mainMod + [0-9]
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# Scroll through existing workspaces with mainMod + scroll

# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

binde= , xf86audioraisevolume, exec, amixer sset Master 5%+
binde= , xf86audiolowervolume, exec, amixer sset Master 5%-
binde= , xf86audiomute, exec, amixer set Master toggle

bind = $mainMod, y, exec, hyprctl clients > gol.txt

# exec-once=dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
